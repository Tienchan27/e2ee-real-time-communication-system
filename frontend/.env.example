# Same-origin via gateway :80 — use relative API path
VITE_API_BASE_URL=/api/v1
# Empty = socket.io-client uses current host (recommended behind gateway)
VITE_SOCKET_BASE_URL=

# WebRTC / ICE config (build-time — phai build lai FE khi doi)
# STUN: comma-separated stun: URLs; để trống = dùng Google STUN fallback
VITE_STUN_SERVERS=stun:stun.l.google.com:19302
# TURN: coturn trong compose local — browser trên host dùng localhost:3478
# PROD (EC2): VITE_TURN_URL=turn:<domain-hoac-ElasticIP>:3478 + credential manh (khop turnserver.conf)
VITE_TURN_URL=turn:localhost:3478
VITE_TURN_USERNAME=devuser
VITE_TURN_CREDENTIAL=devpass
