PORT=3000
# PROD (EC2): doi thanh production
NODE_ENV=development
LOG_LEVEL=info
# PROD: dung POSTGRES_PASSWORD manh (khop .env.prod), host van la "postgres"
DATABASE_URL=postgresql://e2ee_user:e2ee_pass@postgres:5432/e2ee_app
# PROD: random manh; JWT_ACCESS_SECRET + API_INTERNAL_TOKEN phai KHOP realtime-service/.env
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
API_INTERNAL_TOKEN=change-me
REALTIME_INTERNAL_BASE_URL=http://realtime-service:4000
# PROD: CORS_ALLOWED_ORIGINS=https://<domain>
CORS_ALLOWED_ORIGINS=http://localhost
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM=your-account@gmail.com
