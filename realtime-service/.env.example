PORT=4000
NODE_ENV=development
LOG_LEVEL=info
CLIENT_URL=http://localhost
SOCKET_CORS_ORIGINS=http://localhost
API_INTERNAL_BASE_URL=http://api-service:3000
# Must match api-service; rotate in staging/prod (see docs/07 secrets matrix)
API_INTERNAL_TOKEN=change-me
# Must match api-service JWT_ACCESS_SECRET
JWT_ACCESS_SECRET=change-me
# Local dev only — set false or omit in staging/prod
ALLOW_DEV_CONVERSATION_ACCESS=true
# Local dev only — set false in staging/prod
ALLOW_DEV_MESSAGE_PERSIST=true
CALL_INVITE_TIMEOUT_MS=30000
STALE_CLEANUP_INTERVAL_MS=15000
SOCKET_PING_INTERVAL_MS=25000
SOCKET_PING_TIMEOUT_MS=20000
