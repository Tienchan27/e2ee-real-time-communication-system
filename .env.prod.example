# Root compose vars cho PROD (single VM / EC2). Copy -> .env.prod va sua.
# Dung: docker compose -f compose.yaml -f compose.prod.yaml --env-file .env.prod up -d --build
BUILD_TARGET=runtime
# TLS gateway — tao infra/nginx/nginx.ssl.conf va co cert Let's Encrypt
NGINX_CONF=nginx.ssl.conf
POSTGRES_DB=e2ee_app
POSTGRES_USER=e2ee_user
# Doi gia tri nay tren server — KHONG dung 'change-me-on-server'
POSTGRES_PASSWORD=change-me-on-server

# Per-service secrets nam o file rieng (compose doc qua env_file):
#   api-service/.env       — NODE_ENV=production, DATABASE_URL (khop POSTGRES_PASSWORD),
#                            JWT_*, API_INTERNAL_TOKEN, SMTP_*, CORS_ALLOWED_ORIGINS=https://<domain>
#   realtime-service/.env  — NODE_ENV=production, JWT_ACCESS_SECRET + API_INTERNAL_TOKEN (khop api),
#                            SOCKET_CORS_ORIGINS=https://<domain>, ALLOW_DEV_MESSAGE_PERSIST=false
#   frontend/.env          — VITE_* (build-time): VITE_TURN_URL=turn:<domain>:3478, VITE_TURN_USERNAME/CREDENTIAL
# Xem docs/08-aws-ec2-deploy.md va secrets matrix trong docs/07-deployment-cicd.md
